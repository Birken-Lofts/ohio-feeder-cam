# Copy this file to .env and fill in real values:  cp .env.example .env && chmod 600 .env
# .env is gitignored — never commit real credentials.

# --- Camera (Axis RTSP) ---
CAM_USER=root
CAM_PASS=changeme                                   # camera password
CAM_IP=192.168.30.43                                # camera LAN IP
CAM_PATH=/axis-media/media.amp?streamprofile=restream

# --- Restream (RTMP/FLV ingest) ---
RESTREAM_URL=rtmps://live.restream.io:1937/live
RESTREAM_KEY=re_xxxxxxxxxxxxxxxxxxxx                 # use the channel's persistent RTMP key (not an _event key)

# --- Vehicle counting (YOLO -> SQLite -> overlay) ---
# Run calibrate_line.py to draw the counting line(s); it writes these for you.
# Coords are in 1920x1080 (stream) space: "x1,y1,x2,y2". On a divided road draw
# one line per carriageway -- each line becomes a direction. At least one required.
COUNT_LINE_A=                                        # near carriageway -> DIR_A_LABEL
COUNT_LINE_B=                                        # far carriageway  -> DIR_B_LABEL (omit if undivided)
DIR_A_LABEL=NB                                       # e.g. NB / WB
DIR_B_LABEL=SB                                       # e.g. SB / EB
SITE=site1                                           # camera/site id stored on every crossing row
YOLO_MODEL=yolo11n.pt                                # n=fast (dev/CPU/MPS); m/l=accurate (prod GPU)
DETECT_CONF=0.3                                      # detection confidence threshold
DETECT_STRIDE=6                                      # process 1 of N frames (~30fps/6 = 5 detections/s)

# Per-crossing classification (stored in Postgres)
ENABLE_COLOR=true                                    # dominant color name
ENABLE_MMR=false                                     # EXPERIMENTAL make/model; unreliable on traffic cams -- keep off
# Only if you set ENABLE_MMR=true (also: pip install transformers pillow):
# MMR_MODEL=therealcyberlord/stanford-car-vit-patch16  # any HF image-classification model id
# MMR_MIN_PX=64                                        # skip make/model on boxes narrower than this

# Postgres store (the `postgres` compose service). Native dev connects on
# localhost; the counter CONTAINER overrides DATABASE_URL to host `postgres`.
# Leave DATABASE_URL blank to fall back to a local SQLite file (data/counts.db).
POSTGRES_USER=feedercam
POSTGRES_PASSWORD=changeme
POSTGRES_DB=feedercam
DATABASE_URL=postgresql://feedercam:changeme@localhost:5432/feedercam

# --- Production server only (NVIDIA GPU) ---
# Uncomment on the prod box so a plain `docker compose up -d` starts EVERYTHING
# (stream + postgres + GPU vehicle-counter). Leave it commented on the dev Mac,
# which has no NVIDIA GPU and runs the counter natively instead.
# COMPOSE_PROFILES=gpu
# COUNTS_FILE defaults to data/... (relative); containers resolve it to /app/data
# via the ./data mount, so leave it unset unless relocating.

# --- Weather data (overlay) ---
# Preferred: local Davis WeatherLink Live. Set WLL_HOST and it takes priority.
WLL_HOST=                                            # WeatherLink Live LAN IP; leave blank until installed
WLL_PORT=80
POLL_SECONDS=30
# Fallback: Open-Meteo (free, no API key). Used only when WLL_HOST is blank.
# Set to the camera's location (decimal degrees).
WX_LAT=39.9612
WX_LON=-82.9988

# --- Encode ---
X264_PRESET=veryfast     # ultrafast<superfast<veryfast<faster<fast<medium  (left=less CPU)
VBITRATE=8000k           # target/cap for 1080p30
VBUFSIZE=16000k          # ~2x bitrate
OVERLAY_FPS=4            # how often ffmpeg pulls a fresh overlay frame from the renderer
WIDTH=1920
HEIGHT=1080
TZ=America/Chicago       # clock on the overlay

# --- Overlay branding / look ---
PROP_NAME=Your Property
PROP_URL=yourproperty.com
CONSTRUCTION_LOGO=/app/assets/construction_logo.png
PROPERTY_LOGO=/app/assets/property_logo.png
# If no PROPERTY_LOGO image exists, the property slot renders this text as a
# serif wordmark (one word per line). Defaults to PROP_NAME.
# PROP_BRAND=Your Property
BAR_RGB=13,27,42         # panel color
ACCENT_RGB=240,103,48    # brand accent
BAR_ALPHA=150            # panel opacity 0-255 (lower = more see-through)
PANEL_W=330              # vertical panel width
PANEL_SIDE=right         # right or left
